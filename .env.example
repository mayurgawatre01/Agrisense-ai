# CropSense — Environment Configuration
# Copy this file to ".env" and fill in your own values.

# Flask secret key (change in production)
SECRET_KEY=cropsense-secret-2024

# OpenWeatherMap API key (optional) — used for the topbar weather widget.
# Leave blank to use mock weather data.
# Get a free key at: https://openweathermap.org/api
WEATHER_API_KEY=

# data.gov.in API key (optional) — used for the live Mandi Price Tracker.
# Leave blank to use the built-in public demo key + offline fallback data.
# Get your own free key at: https://data.gov.in/ (Sign Up -> My Account -> API Key)
DATA_GOV_API_KEY=

# Anthropic API key (fallback for the Pest/Disease Identifier's AI photo
# analysis — used automatically only if GEMINI_API_KEY is missing/fails).
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API key (PRIMARY — used first for the Pest/Disease
# Identifier's AI photo analysis). Gemini has a generous free tier, so
# this is the recommended key to set up first.
# Without either GEMINI_API_KEY or ANTHROPIC_API_KEY, the page still works
# but shows a "not configured" message instead of an AI diagnosis.
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
